{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Europe/Paris",
  "labels": ["dependencies"],
  "dependencyDashboardTitle": "Dependency Dashboard",
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "Compendium framework packages — group, immediate schedule, manual review required",
      "matchPackagePatterns": ["^Compendium\\."],
      "groupName": "compendium-framework",
      "schedule": ["at any time"],
      "automerge": false,
      "labels": ["dependencies", "compendium-framework"]
    },
    {
      "description": "All other dependencies — weekly, automerge patch + minor",
      "matchUpdateTypes": ["patch", "minor"],
      "matchPackagePatterns": ["^(?!Compendium\\.)"],
      "schedule": ["before 6am on monday"],
      "automerge": true
    },
    {
      "description": "GitHub Actions — weekly, automerge",
      "matchManagers": ["github-actions"],
      "schedule": ["before 6am on monday"],
      "automerge": true,
      "labels": ["dependencies", "github-actions"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
